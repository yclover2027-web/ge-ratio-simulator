{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "api/latest-mhlw-master.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/latest-mhlw-master", "dest": "/api/latest-mhlw-master.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
